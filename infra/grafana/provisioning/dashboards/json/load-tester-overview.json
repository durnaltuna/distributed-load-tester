{
  "id": null,
  "uid": "loadtester-overview",
  "title": "Distributed Load Tester Overview",
  "tags": ["load-tester", "cv-project"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requests Per Second",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(load_tester_requests_total[1m]))",
          "legendFormat": "rps"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate Per Second",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(load_tester_errors_total[1m]))",
          "legendFormat": "errors/s"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "P99 Latency by Test (ms)",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "max by (testId) (load_tester_p99_latency_ms)",
          "legendFormat": "{{testId}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Tests",
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "load_tester_active_tests"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  }
}